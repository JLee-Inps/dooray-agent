{
  "name": "dooray-agent",
  "version": "0.1.0",
  "description": "Agent-friendly CLI for reading and writing NHN Dooray documents from the terminal and Claude Code",
  "keywords": [
    "dooray",
    "cli",
    "agent",
    "automation",
    "wiki",
    "task"
  ],
  "license": "MIT",
  "author": "JLee-Inps",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JLee-Inps/dooray-agent.git"
  },
  "homepage": "https://github.com/JLee-Inps/dooray-agent#readme",
  "bugs": {
    "url": "https://github.com/JLee-Inps/dooray-agent/issues"
  },
  "type": "module",
  "bin": {
    "dooray-agent": "dist/cli.js",
    "dra": "dist/cli.js",
    "dooray-agent-mcp": "dist/mcp.js"
  },
  "files": [
    "dist/*.js",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "imapflow": "^1.4.3",
    "js-yaml": "^4.1.1",
    "ky": "^1.14.3",
    "mailparser": "^3.9.12",
    "nodemailer": "^9.0.1",
    "ora": "^9.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^8.0.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "prettier": "^3.9.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.5"
  }
}
